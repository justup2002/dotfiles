# Local machine overrides — never tracked
*.local
.zshrc.local
profile.local.ps1

# Dev container config — not part of dotfiles
.devcontainer/

# Byte-compiled zsh (generated in-place next to sources)
*.zwc

# OS junk
.DS_Store
Thumbs.db
desktop.ini

# Backups left by bootstrap
*.backup.*

# Editor
.vscode/
.idea/
*.swp
*~
