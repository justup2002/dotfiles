{
    // Merge into User settings.json (Ctrl+Shift+P → "Preferences: Open User Settings (JSON)")
    // Install the theme first: code --install-extension zhuangtongfa.material-theme

    "workbench.colorTheme": "One Dark Pro",

    "terminal.integrated.fontFamily": "'MesloLGS NF', 'Cascadia Code', 'Consolas', monospace",
    "terminal.integrated.fontSize": 13,
    "terminal.integrated.lineHeight": 1.1,
    "terminal.integrated.cursorBlinking": true,
    "terminal.integrated.cursorStyle": "bar",
    "terminal.integrated.smoothScrolling": true,
    "terminal.integrated.gpuAcceleration": "on",

    "terminal.integrated.defaultProfile.linux": "zsh",
    "terminal.integrated.defaultProfile.osx": "zsh",
    "terminal.integrated.defaultProfile.windows": "PowerShell",

    "terminal.integrated.profiles.linux": {
        "zsh": { "path": "zsh", "args": ["-l"] }
    },
    "terminal.integrated.profiles.windows": {
        "PowerShell": { "source": "PowerShell", "icon": "terminal-powershell" },
        "PowerShell 7 (pwsh)": {
            "path": "C:\\Program Files\\PowerShell\\7\\pwsh.exe",
            "args": ["-NoLogo"],
            "icon": "terminal-powershell"
        },
        "Ubuntu (WSL)": { "path": "wsl.exe", "args": ["-d", "Ubuntu"] }
    },

    "editor.fontFamily": "'MesloLGS NF', 'Cascadia Code', 'Consolas', monospace",
    "editor.fontLigatures": true
}
